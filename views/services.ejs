<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services - BRANDLE</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">
                <div class="logo-icon">B</div>
                <span>BRANDLE</span>
            </div>
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">Home</a></li>
                <li><a href="/services" class="nav-link active">Services</a></li>
                <li><a href="/contact" class="nav-link">Contact</a></li>
            </ul>
            <button class="cta-btn">Get Started</button>
        </div>
    </nav>

    <!-- Services Hero -->
    <section style="min-height: 60vh; padding: 120px 1.5rem 60px; background: linear-gradient(135deg, #000 0%, #1a1a1a 100%); display: flex; align-items: center;">
        <div style="max-width: 1280px; margin: 0 auto; text-align: center;">
            <h1 style="font-size: 4rem; font-weight: 900; margin-bottom: 1rem;">
                Our <span class="gradient-text">Services</span>
            </h1>
            <p style="color: #9ca3af; font-size: 1.25rem; max-width: 600px; margin: 0 auto;">
                Comprehensive solutions designed to scale your creator business
            </p>
        </div>
    </section>

    <!-- Services Grid -->
    <section style="padding: 6rem 1.5rem; max-width: 1280px; margin: 0 auto;">
        <div id="services-container" class="services-grid">
            <!-- Loaded dynamically -->
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-col">
                <div class="logo-footer">
                    <div class="logo-icon-footer">B</div>
                    <span>BRANDLE</span>
                </div>
                <p>Empowering creators worldwide</p>
            </div>
            <div class="footer-links">
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
                <a href="#">Contact</a>
            </div>
            <p class="copyright">&copy; 2024 BRANDLE. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
