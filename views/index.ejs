<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BRANDLE - Creator Management</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background-color: #000;
            color: #fff;
            overflow-x: hidden;
        }

        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.5);
        }

        ::-webkit-scrollbar-thumb {
            background: #FFC700;
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #FFD700;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 50;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(250, 204, 21, 0.2);
            padding: 1.25rem 0;
        }

        .nav-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.5rem;
            font-weight: 900;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #FFC700 0%, #FFD700 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-weight: bold;
        }

        .nav-links {
            display: none;
            gap: 2.5rem;
        }

        .nav-links a {
            text-decoration: none;
            color: #a3a3a3;
            font-size: 0.875rem;
            font-weight: 500;
            transition: color 0.3s;
            cursor: pointer;
        }

        .nav-links a:hover {
            color: #FFC700;
        }

        @media (min-width: 768px) {
            .nav-links {
                display: flex;
            }
        }

        .cta-button {
            padding: 0.625rem 1.5rem;
            background: linear-gradient(135deg, #FFC700 0%, #FFD700 100%);
            color: #000;
            border: none;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 0 20px rgba(255, 199, 0, 0.3);
        }

        .cta-button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px rgba(255, 199, 0, 0.6);
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            padding-top: 80px;
            padding-left: 1.5rem;
            padding-right: 1.5rem;
            display: flex;
            align-items: center;
            overflow: hidden;
            background: linear-gradient(to bottom, #000 0%, #000 50%, rgba(250, 204, 21, 0.05) 100%);
            position: relative;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 80px;
            right: 25%;
            width: 384px;
            height: 384px;
            background: rgba(255, 199, 0, 0.1);
            border-radius: 50%;
            filter: blur(120px);
            animation: float 8s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-30px); }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .hero-content {
            max-width: 1280px;
            width: 100%;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }

        .hero-left {
            animation: fadeInUp 0.8s ease-out;
        }

        .hero-left > * + * {
            margin-top: 1.5rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: rgba(255, 199, 0, 0.1);
            border: 1px solid rgba(250, 204, 21, 0.4);
            border-radius: 9999px;
            width: fit-content;
        }

        .badge-dot {
            width: 8px;
            height: 8px;
            background-color: #FFC700;
            border-radius: 50%;
            animation: pulse 2s ease-in-out infinite;
        }

        .badge-text {
            color: #FCD34D;
            font-size: 0.875rem;
            font-weight: 600;
        }

        h1 {
            font-size: 3.75rem;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 1.5rem;
        }

        @media (min-width: 1024px) {
            h1 {
                font-size: 4.5rem;
            }
        }

        .gradient-text {
            background: linear-gradient(90deg, #FCD34D 0%, #FFC700 50%, #FFD700 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-description {
            font-size: 1.125rem;
            color: #d1d5db;
            line-height: 1.6;
            max-width: 448px;
        }

        .cta-group {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 2rem;
        }

        @media (min-width: 640px) {
            .cta-group {
                flex-direction: row;
            }
        }

        .primary-btn {
            padding: 1rem 2rem;
            background: linear-gradient(135deg, #FFC700 0%, #FFD700 100%);
            color: #000;
            border: none;
            border-radius: 0.5rem;
            font-weight: 700;
            font-size: 1.125rem;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            box-shadow: 0 0 30px rgba(255, 199, 0, 0.4);
        }

        .primary-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 40px rgba(255, 199, 0, 0.6);
        }

        .secondary-btn {
            padding: 1rem 2rem;
            border: 2px solid rgba(250, 204, 21, 0.4);
            background: transparent;
            color: #fff;
            border-radius: 0.5rem;
            font-weight: 700;
            font-size: 1.125rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .secondary-btn:hover {
            border-color: #FFC700;
            background: rgba(255, 199, 0, 0.05);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(250, 204, 21, 0.2);
            margin-top: 2rem;
        }

        .stat-number {
            font-size: 1.875rem;
            font-weight: 900;
            color: #FFC700;
            display: block;
        }

        .stat-label {
            font-size: 0.75rem;
            color: #9ca3af;
            margin-top: 0.25rem;
        }

        /* Services Section */
        .services {
            padding: 5rem 1.5rem;
            background: #000;
            position: relative;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-label {
            display: inline-block;
            padding: 0.5rem 1rem;
            background: rgba(255, 199, 0, 0.1);
            border: 1px solid rgba(250, 204, 21, 0.4);
            border-radius: 9999px;
            margin-bottom: 1rem;
        }

        .section-label-text {
            color: #FCD34D;
            font-size: 0.875rem;
            font-weight: 700;
        }

        h2 {
            font-size: 3rem;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 1rem;
        }

        @media (min-width: 1024px) {
            h2 {
                font-size: 3.75rem;
            }
        }

        .section-description {
            color: #9ca3af;
            font-size: 1.125rem;
            max-width: 672px;
            margin: 1rem auto 0;
        }

        .services-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            max-width: 1280px;
            margin: 0 auto;
        }

        @media (min-width: 768px) {
            .services-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .services-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .service-card {
            position: relative;
            background: linear-gradient(135deg, rgba(255, 199, 0, 0.1) 0%, #000 100%);
            border: 1px solid rgba(250, 204, 21, 0.2);
            border-radius: 1rem;
            padding: 2rem;
            overflow: hidden;
            transition: all 0.3s;
            cursor: pointer;
        }

        .service-card:hover {
            border-color: rgba(255, 199, 0, 0.6);
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(255, 199, 0, 0.1);
        }

        .service-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .service-description {
            color: #d1d5db;
            font-size: 0.875rem;
            line-height: 1.6;
        }

        /* Stats Section */
        .stats {
            padding: 5rem 1.5rem;
            background: #000;
        }

        .stats-grid-2 {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            max-width: 1280px;
            margin: 0 auto;
        }

        @media (min-width: 768px) {
            .stats-grid-2 {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .stats-grid-2 {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(255, 199, 0, 0.15) 0%, #000 100%);
            border: 1px solid rgba(250, 204, 21, 0.3);
            border-radius: 1rem;
            padding: 2rem;
            text-align: center;
            transition: all 0.3s;
        }

        .stat-card:hover {
            border-color: rgba(255, 199, 0, 0.6);
            transform: translateY(-10px);
        }

        .stat-num {
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(90deg, #FCD34D 0%, #FFC700 50%, #FFD700 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: block;
            margin-bottom: 1rem;
        }

        .stat-txt {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .stat-sub {
            color: #9ca3af;
            font-size: 0.875rem;
        }

        /* Footer */
        footer {
            background: rgba(0, 0, 0, 0.8);
            border-top: 1px solid rgba(255, 199, 0, 0.1);
            padding: 2rem 1.5rem;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 2rem;
        }

        .footer-col {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .logo-footer {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 700;
        }

        .logo-icon-footer {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #FFC700 0%, #FFD700 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 0.875rem;
            font-weight: bold;
        }

        .footer-col p {
            color: #9ca3af;
            font-size: 0.875rem;
        }

        .footer-links {
            display: flex;
            gap: 2rem;
        }

        .footer-links a {
            color: #9ca3af;
            text-decoration: none;
            font-size: 0.875rem;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: #FFC700;
        }

        .copyright {
            color: #9ca3af;
            font-size: 0.875rem;
            width: 100%;
            text-align: center;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="nav-container">
            <div class="logo">
                <div class="logo-icon">B</div>
                <span>BRANDLE</span>
            </div>
            <div class="nav-links">
                <a href="#services">Services</a>
                <a href="#stats">Stats</a>
            </div>
            <button class="cta-button">Get Started</button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <div class="hero-left">
                <div class="badge">
                    <span class="badge-dot"></span>
                    <span class="badge-text">For Ambitious Creators</span>
                </div>

                <h1>Turn Your <span class="gradient-text">Passion</span> Into <span class="gradient-text">Fortune</span></h1>

                <p class="hero-description">
                    BRANDLE is the AI-powered management platform trusted by 500+ creators. We handle the business complexities while you focus on creating world-class content.
                </p>

                <div class="cta-group">
                    <button class="primary-btn">Start Growing Today →</button>
                    <button class="secondary-btn">Watch Demo</button>
                </div>

                <div class="stats-grid">
                    <div>
                        <span class="stat-number">500+</span>
                        <span class="stat-label">Creators Managed</span>
                    </div>
                    <div>
                        <span class="stat-number">3.5x</span>
                        <span class="stat-label">Avg. Growth Rate</span>
                    </div>
                    <div>
                        <span class="stat-number">98%</span>
                        <span class="stat-label">Satisfaction</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <div class="section-header">
                <div class="section-label">
                    <span class="section-label-text">WHAT WE DO</span>
                </div>
                <h2>Comprehensive Creator <span class="gradient-text">Management Services</span></h2>
            </div>

            <div class="services-grid" id="services-container">
                <!-- Loaded via API -->
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section id="stats" class="stats">
        <div class="container">
            <div class="section-header">
                <h2>Our <span class="gradient-text">Impact</span></h2>
            </div>

            <div class="stats-grid-2" id="stats-container">
                <!-- Loaded via API -->
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <div class="footer-col">
                <div class="logo-footer">
                    <div class="logo-icon-footer">B</div>
                    <span>BRANDLE</span>
                </div>
                <p>Empowering creators worldwide</p>
            </div>
            <div class="footer-links">
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
                <a href="#">Contact</a>
            </div>
            <p class="copyright">&copy; 2024 BRANDLE. All rights reserved.</p>
        </div>
    </footer>

    <script>
        async function loadServices() {
            try {
                const response = await fetch('/api/services');
                const services = await response.json();
                const container = document.getElementById('services-container');
                services.forEach((service) => {
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.innerHTML = `<h3 class="service-title">${service.title}</h3><p class="service-description">Professional management to scale your presence.</p>`;
                    container.appendChild(card);
                });
            } catch (e) { console.log('Services loaded'); }
        }

        async function loadStats() {
            try {
                const response = await fetch('/api/stats');
                const stats = await response.json();
                const container = document.getElementById('stats-container');
                stats.forEach((stat) => {
                    const card = document.createElement('div');
                    card.className = 'stat-card';
                    card.innerHTML = `<div class="stat-num">${stat.number}</div><div class="stat-txt">${stat.label}</div><div class="stat-sub">${stat.sublabel}</div>`;
                    container.appendChild(card);
                });
            } catch (e) { console.log('Stats loaded'); }
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadServices();
            loadStats();
        });
    </script>
</body>
</html>
